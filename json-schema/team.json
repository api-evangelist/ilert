{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.ilert.com/schemas/Team",
  "title": "Team",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "format": "int64"
    },
    "name": {
      "type": "string"
    },
    "visibility": {
      "$ref": "#/components/schemas/TeamVisibilityType"
    },
    "members": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/TeamMember"
      }
    },
    "createdAt": {
      "type": "string",
      "description": "Date in ISO-8601",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "description": "Date in ISO-8601",
      "format": "date-time"
    }
  }
}