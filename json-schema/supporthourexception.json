{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.ilert.com/schemas/SupportHourException",
  "title": "SupportHourException",
  "type": "object",
  "required": [
    "name",
    "start",
    "end",
    "supportStatus"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "start": {
      "type": "string",
      "format": "date"
    },
    "end": {
      "type": "string",
      "format": "date"
    },
    "supportStatus": {
      "type": "string",
      "enum": [
        "DURING",
        "OUTSIDE"
      ]
    }
  }
}