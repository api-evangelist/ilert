{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.ilert.com/schemas/EventFlowBranch",
  "title": "EventFlowBranch",
  "type": "object",
  "required": [
    "branchType"
  ],
  "properties": {
    "id": {
      "type": "integer",
      "format": "int64"
    },
    "branchType": {
      "type": "string",
      "enum": [
        "BRANCH",
        "CATCH_ALL",
        "ACCEPTED"
      ]
    },
    "condition": {
      "type": "string"
    },
    "target": {
      "$ref": "#/components/schemas/EventFlowNode"
    }
  }
}