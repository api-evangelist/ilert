{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.ilert.com/schemas/CallFlowNodeMetadataGather",
  "title": "CallFlowNodeMetadataGather",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "CALLER_NAME",
        "CONTACT_NUMBER",
        "EMAIL",
        "INCIDENT",
        "AFFECTED_SERVICES"
      ]
    },
    "label": {
      "type": "string"
    },
    "varType": {
      "type": "string",
      "enum": [
        "NUMBER",
        "DATE",
        "BOOLEAN",
        "STRING"
      ]
    },
    "required": {
      "type": "boolean"
    },
    "question": {
      "type": "string"
    }
  }
}