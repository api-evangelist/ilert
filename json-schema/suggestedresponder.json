{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.ilert.com/schemas/SuggestedResponder",
  "title": "SuggestedResponder",
  "type": "object",
  "properties": {
    "group": {
      "type": "string",
      "enum": [
        "SUGGESTED",
        "USER",
        "ESCALATION_POLICY",
        "ON_CALL_SCHEDULE"
      ]
    },
    "id": {
      "type": "number"
    },
    "name": {
      "type": "string"
    },
    "disabled": {
      "type": "boolean"
    }
  }
}