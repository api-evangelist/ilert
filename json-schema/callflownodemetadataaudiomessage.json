{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.ilert.com/schemas/CallFlowNodeMetadataAudioMessage",
  "title": "CallFlowNodeMetadataAudioMessage",
  "type": "object",
  "properties": {
    "textMessage": {
      "type": "string"
    },
    "customAudioUrl": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "enum": [
        "en",
        "de",
        "fr",
        "es",
        "nl",
        "ru",
        "it"
      ]
    },
    "aiVoiceModel": {
      "type": "string",
      "enum": [
        "emma",
        "liam",
        "isabelle",
        "gordon",
        "ivy",
        "ellen"
      ]
    }
  }
}