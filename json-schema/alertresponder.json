{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.ilert.com/schemas/AlertResponder",
  "title": "AlertResponder",
  "type": "object",
  "properties": {
    "user": {
      "$ref": "#/components/schemas/UserRel"
    },
    "status": {
      "type": "string",
      "enum": [
        "PENDING",
        "ACCEPTED"
      ]
    },
    "acceptedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}