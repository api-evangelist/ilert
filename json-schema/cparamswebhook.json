  "$id": "https://api.ilert.com/schemas/CParamsWebhook",
  "title": "CParamsWebhook",
  "required": [
    "webhookUrl"
  ],
  "type": "object",
  "properties": {
    "webhookUrl": {
      "type": "string"
    },
    "bodyTemplate": {
      "type": "string"
    },
    "headers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "key",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      }
    }
  }
}