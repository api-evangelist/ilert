{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.ilert.com/schemas/SingleTimePoint",
  "title": "SingleTimePoint",
  "required": [
    "value"
  ],
  "type": "object",
  "properties": {
    "timestamp": {
      "type": "number",
      "description": "The unix epoch second of your time point",
      "format": "int64"
    },
    "value": {
      "type": "number",
      "description": "Value of your time point",
      "format": "double"
    }
  }
}