{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.ilert.com/schemas/IncidentTemplate",
  "title": "IncidentTemplate",
  "type": "object",
  "properties": {
    "id": {
      "type": "number"
    },
    "name": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "status": {
      "$ref": "#/components/schemas/IncidentStatus"
    },
    "message": {
      "type": "string"
    },
    "sendNotification": {
      "type": "boolean"
    },
    "teams": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/TeamRel"
      }
    }
  }
}